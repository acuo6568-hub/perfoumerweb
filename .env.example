# Example environment variables for background removal

# Point your app to a running rembg HTTP service (default local Docker run)
REMBG_API_URL=http://localhost:5000

# Optional: If using an external provider that requires an API key
# e.g. 'Bearer <token>' or just the raw key depending on provider
REMBG_API_KEY=
REMBG_API_KEY_HEADER=Authorization

# Which rembg model to use (u2net, u2netp, u2net_human_seg, u2net_cloth_seg)
REMBG_MODEL=u2net

# If you're running Python locally instead of REMBG_API_URL, set python path
PYTHON_PATH=/usr/bin/python3
